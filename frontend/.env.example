# Google Analytics 4 측정 ID — saju.sedaily.ai 용
# - analytics.google.com 속성 생성 후 웹 데이터 스트림에서 확인
# - 로컬/프리뷰엔 설정하지 않아도 됨 (런타임 hostname 체크로 자동 무시)
# - 빌드 시점에 주입되므로 변경 후 `./scripts/deploy.sh both` 재실행 필요
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 사주 챗봇 실시간 LLM 백엔드 (Bedrock) Function URL
# - 미설정 시 챗봇은 규칙 기반 템플릿으로 폴백 (실시간 LLM 미사용, 비용 $0)
# - 설정 시 자유 입력 의도분류 + 매듭 서술을 LLM 이 생성 (메시지당 비용 발생)
# - 참조 백엔드: scripts/lambda/chat-bedrock/
NEXT_PUBLIC_CHAT_API_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws/
